{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Basis controller + agent state. Every panel is backed by a metric the controller actually emits (see crates/basis-controller/src/metrics.rs).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Cluster state",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Current VM count per state.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "RUNNING" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#56a64b" } }] },
          { "matcher": { "id": "byName", "options": "CREATING" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794f2" } }] },
          { "matcher": { "id": "byName", "options": "PENDING" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8ab8ff" } }] },
          { "matcher": { "id": "byName", "options": "STOPPING" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ff9830" } }] },
          { "matcher": { "id": "byName", "options": "STOPPED" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8e8e8e" } }] },
          { "matcher": { "id": "byName", "options": "FAILED" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } }] }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "barRadius": 0,
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "legend": { "displayMode": "hidden", "placement": "bottom", "showLegend": false },
        "orientation": "vertical",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (state) (basis_vms{cluster=~\"$cluster\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "VM states",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true }
          }
        }
      ],
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-host health over time. One row per host, coloured by heartbeat age — green under 60s (healthy), yellow 60–90s (approaching stale), red ≥90s (controller flips the host to unhealthy and the scheduler stops placing on it). Tooltip shows the exact age in seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#56a64b", "value": null },
              { "color": "#ff9830", "value": 60 },
              { "color": "#e02f44", "value": 90 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_last_heartbeat_age_seconds",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "title": "Hosts (heartbeat state by host)",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Number of clusters registered with the controller.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never"
          },
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_clusters",
          "legendFormat": "clusters",
          "refId": "A"
        }
      ],
      "title": "Clusters",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Fraction of GPU devices currently assigned to VMs across all healthy hosts. `clamp_min(total, 1)` guards the divide when no GPU hosts are registered.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never"
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "100 * sum(basis_host_gpus_assigned) / clamp_min(sum(basis_host_gpus_total), 1)",
          "legendFormat": "gpu",
          "refId": "A"
        }
      ],
      "title": "GPU utilization",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 200,
      "panels": [],
      "title": "Flow",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Successful CreateMachine rate (ops/s). A sudden drop while Failures climbs means basis is shedding load or broken.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(basis_vm_create_result_total{result=\"placed\"}[5m]))",
          "legendFormat": "placed",
          "refId": "A"
        }
      ],
      "title": "VM creation throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Scheduler placement decisions by outcome. `placed` means a host was selected; anything else (insufficient_capacity, no_gpu, etc.) is a rejection and worth investigating if sustained.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (outcome) (rate(basis_scheduler_decisions_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Scheduler decisions (by outcome)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "CreateMachine failure rate, broken out by terminal result (everything except `placed`). `busy` is agent backpressure and self-recovers; any other result at a sustained non-zero rate warrants investigation — `no_capacity` means the scheduler couldn't place, `vm_failed` means the agent reported a real fault, `timeout` means the controller gave up on a slow agent.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none", "group": "A" }
          },
          "min": 0,
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "busy" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ff9830" } }] },
          { "matcher": { "id": "byName", "options": "no_capacity" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#fade2a" } }] },
          { "matcher": { "id": "byName", "options": "no_agent" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } }] },
          { "matcher": { "id": "byName", "options": "stream_closed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } }] },
          { "matcher": { "id": "byName", "options": "agent_error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } }] },
          { "matcher": { "id": "byName", "options": "vm_failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#c4162a" } }] },
          { "matcher": { "id": "byName", "options": "timeout" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#c4162a" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 24 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (result) (rate(basis_vm_create_result_total{result!=\"placed\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "VM creation failures (by result)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 300,
      "panels": [],
      "title": "Per-host capacity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Assigned vCPU per host over time. Solid line is sum(vm.cpu) assigned to the host. Dashed 'physical' line is the host's logical CPU count (beyond this the kernel time-slices). Dashed 'overcommit' line is physical × basis_cpu_overcommit_ratio — the scheduler's hard ceiling.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*physical.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 6] } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*overcommit.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 6] } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_cpu_assigned",
          "legendFormat": "{{host}} assigned",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_cpu_total",
          "legendFormat": "{{host}} physical",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_cpu_total * scalar(basis_cpu_overcommit_ratio)",
          "legendFormat": "{{host}} overcommit",
          "refId": "C"
        }
      ],
      "title": "CPU assigned by host",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Assigned RAM per host (MiB). Solid line is sum(vm.memory_mib) assigned to the host. Dashed 'max' is the host's physical RAM — memory is never overcommitted.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "unit": "mbytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*max.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 6] } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_memory_mib_assigned",
          "legendFormat": "{{host}} assigned",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_memory_mib_total",
          "legendFormat": "{{host}} max",
          "refId": "B"
        }
      ],
      "title": "Memory assigned by host",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Assigned disk per host (GiB). Solid line is sum(vm.disk_gib). Dashed 'max' is the thin pool size reported at agent registration; sum(vm.disk_gib) is virtual so assigned is a conservative upper bound on physical use. Disk is never overcommitted.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "unit": "gbytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*max.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 6] } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_disk_gib_assigned",
          "legendFormat": "{{host}} assigned",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_disk_gib_total",
          "legendFormat": "{{host}} max",
          "refId": "B"
        }
      ],
      "title": "Disk assigned by host",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "id": 400,
      "panels": [],
      "title": "Stuck states",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "VMs that have been in PENDING/CREATING/STOPPING for more than 2 minutes. Expected to be empty; any entry is worth investigating (kubeadm bootstrap hang, systemd unit failure, agent crash).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "no stuck VMs",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_vm_age_in_state_seconds{state=~\"PENDING|CREATING|STOPPING\",cluster=~\"$cluster\"} > 120",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Stuck VMs (> 2 min in non-terminal state)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "indexByName": { "name": 0, "state": 1, "cluster": 2, "host": 3, "Value": 4 },
            "renameByName": { "Value": "age (s)" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Hosts whose last heartbeat is older than 60 seconds. Expected to be empty.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "all hosts healthy",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "id": 31,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_host_last_heartbeat_age_seconds > 60",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Stale hosts (heartbeat > 60s)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "indexByName": { "host": 0, "Value": 1 },
            "renameByName": { "Value": "age (s)" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Agent self-healing signal: resources the orphan sweep has reclaimed (systemd units, LVs, taps) because a delete path raced and left something behind. A non-zero sustained rate means basis is picking up its own leaks — normal; investigate only if the rate never tapers (indicates the leak is faster than the sweep). Zero is the steady state.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "unit": "ops"
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 29 },
      "id": 32,
      "options": {
        "legend": { "calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (kind) (rate(basis_agent_orphan_sweep_reclaimed_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "title": "Orphans reclaimed (self-healing rate)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 500,
      "panels": [],
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
