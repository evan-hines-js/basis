{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-agent VM create pipeline breakdown plus per-VM resource usage. Each histogram is observed on the agent at one step of handlers::create_vm_inner — when the controller dashboard shows an end-to-end latency jump, this dashboard tells you which step moved. The per-VM section shows live cgroup accounting for every VM the agent currently manages. Filter by host via the `instance` variable.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Per-step create latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "p95 of every step in handlers::create_vm_inner on the agent, on one panel. When the controller's CreateMachine p95 jumps, exactly one of these six lines will jump with it — that's the step doing the waiting. Lines near zero are healthy; a line climbing into tens of seconds is the suspect.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "min": 0,
          "unit": "s"
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_image_ensure_cached_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "image_ensure_cached",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_lv_snapshot_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "lv_snapshot",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_cloud_init_iso_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "cloud_init_iso",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_tap_create_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "tap_create",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_vfio_bind_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "vfio_bind",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_vm_spawn_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "vm_spawn",
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(basis_agent_lv_permit_wait_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "lv_permit_wait",
          "refId": "G"
        }
      ],
      "title": "p95 per step (by name)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 200,
      "panels": [],
      "title": "Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-step completion rate. Derived from the histogram's own `_count` series so the integral matches the count panels on the controller dashboard. Divergence between steps means creates are failing partway through — e.g. image_ensure_cached rate high but vm_spawn rate low = creates dying in the middle of the pipeline.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "min": 0,
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_image_ensure_cached_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "image_ensure_cached",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_lv_snapshot_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "lv_snapshot",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_cloud_init_iso_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "cloud_init_iso",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_tap_create_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "tap_create",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_vm_spawn_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "vm_spawn",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_vfio_bind_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "vfio_bind",
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_lv_permit_wait_seconds_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "lv_permit_wait",
          "refId": "G"
        }
      ],
      "title": "Completion rate per step",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Mean time per step (sum / count). Complements the p95 panel above — if mean rises alongside p95, every create is slower; if p95 rises but mean barely moves, only the tail is affected (more often a contention pattern than a systemic slowdown).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true },
          "min": 0,
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_image_ensure_cached_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_image_ensure_cached_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "image_ensure_cached",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_lv_snapshot_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_lv_snapshot_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "lv_snapshot",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_cloud_init_iso_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_cloud_init_iso_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "cloud_init_iso",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_tap_create_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_tap_create_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "tap_create",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_vm_spawn_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_vm_spawn_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "vm_spawn",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_vfio_bind_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_vfio_bind_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "vfio_bind",
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_lv_permit_wait_seconds_sum{instance=~\"$instance\"}[5m]) / clamp_min(rate(basis_agent_lv_permit_wait_seconds_count{instance=~\"$instance\"}[5m]), 1e-9)",
          "legendFormat": "lv_permit_wait",
          "refId": "G"
        }
      ],
      "title": "Mean time per step",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 300,
      "panels": [],
      "title": "Per-VM (live on this agent)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Every VM the selected agent currently manages, with its identity, allocation, and live cgroup readings. Memory is the systemd MemoryCurrent gauge; CPU is the rate of CPUUsageNSec over the last minute, normalized so 1.0 means one fully-saturated vCPU. Running=0 with the unit still listed means cloud-hypervisor exited but systemd's --remain-after-exit kept the unit visible — usually FAILED.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "memory_bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "memory_limit_bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "disk_gib" }, "properties": [{ "id": "unit", "value": "gbytes" }] },
          { "matcher": { "id": "byName", "options": "cpu_used" }, "properties": [{ "id": "unit", "value": "none" }, { "id": "decimals", "value": 2 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "id": 30,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_info{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "INFO"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_running{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "RUN"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_cpu_quota{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "QUOTA"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_vm_cpu_seconds{instance=~\"$instance\"}[1m])",
          "format": "table",
          "instant": true,
          "refId": "CPUUSE"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_memory_bytes{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "MEM"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_memory_limit_bytes{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "MEMLIM"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_disk_gib{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "DISK"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "vm_id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true, "Time 2": true, "Time 3": true,
              "Time 4": true, "Time 5": true, "Time 6": true, "Time 7": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true,
              "__name__ 4": true, "__name__ 5": true, "__name__ 6": true, "__name__ 7": true,
              "job 1": true, "job 2": true, "job 3": true,
              "job 4": true, "job 5": true, "job 6": true, "job 7": true,
              "instance 2": true, "instance 3": true,
              "instance 4": true, "instance 5": true, "instance 6": true, "instance 7": true
            },
            "renameByName": {
              "instance 1": "instance",
              "Value #INFO": "info",
              "Value #RUN": "running",
              "Value #QUOTA": "vcpus",
              "Value #CPUUSE": "cpu_used",
              "Value #MEM": "memory_bytes",
              "Value #MEMLIM": "memory_limit_bytes",
              "Value #DISK": "disk_gib"
            },
            "indexByName": {
              "vm_id": 0,
              "name": 1,
              "ip": 2,
              "image": 3,
              "running": 4,
              "vcpus": 5,
              "cpu_used": 6,
              "memory_bytes": 7,
              "memory_limit_bytes": 8,
              "disk_gib": 9
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "vm_id",
                "name",
                "ip",
                "image",
                "instance",
                "running",
                "vcpus",
                "cpu_used",
                "memory_bytes",
                "memory_limit_bytes",
                "disk_gib"
              ]
            }
          }
        }
      ],
      "title": "VMs on this agent",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-VM CPU usage, expressed in vCPUs (1.0 = one fully-saturated vCPU). Derived from rate() of the cgroup CPUUsageNSec gauge. A line riding at the VM's vcpu allocation means the guest is CPU-bound; a line near zero means the guest is idle even though it's still running.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1, "spanNulls": true },
          "min": 0,
          "unit": "none",
          "decimals": 2
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 31 },
      "id": 31,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(basis_agent_vm_cpu_seconds{instance=~\"$instance\"}[1m]) * on(vm_id) group_left(name) basis_agent_vm_info{instance=~\"$instance\"}",
          "legendFormat": "{{name}} ({{vm_id}})",
          "refId": "A"
        }
      ],
      "title": "CPU used per VM (vCPUs)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-VM resident memory from the cgroup, with the configured ceiling shown alongside via basis_agent_vm_memory_limit_bytes. A VM whose `memory_bytes` line is pegged at its limit is the right place to look first when a guest workload reports OOMs.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1, "spanNulls": true },
          "min": 0,
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 31 },
      "id": 32,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "basis_agent_vm_memory_bytes{instance=~\"$instance\"} * on(vm_id) group_left(name) basis_agent_vm_info{instance=~\"$instance\"}",
          "legendFormat": "{{name}} ({{vm_id}})",
          "refId": "A"
        }
      ],
      "title": "Memory used per VM",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["basis", "agent"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "definition": "label_values(basis_agent_vm_spawn_seconds_count, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Host (instance)",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": { "query": "label_values(basis_agent_vm_spawn_seconds_count, instance)", "refId": "Prometheus-instance-Variable-Query" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Basis Agent",
  "uid": "basis-agent",
  "version": 3,
  "weekStart": ""
}
