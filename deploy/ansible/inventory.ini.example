# Copy to inventory.ini and edit for your fleet.
#
# Just list the IPs. One dedicated host runs basis-controller (a
# control-plane process, no VMs). Every other host under [basis_agents]
# runs basis-agent and hosts VMs. Heterogeneous hardware is fine — each
# agent's NIC is autodetected from its default-route interface at apply
# time, so a Dell with eno1, a Beelink with enp2s0, and a Proxmox node
# with nic0 can all share the same one-line-per-host inventory.
#
# Overrides (all optional):
#   ansible_host=<ip-or-dns>   SSH target, if the inventory name is a
#                              label rather than a reachable address.
#   basis_physical_nic=<name>  Override NIC autodetection for a host
#                              with multiple NICs or no default route.
#   basis_bridge=<name>        Override the bridge name (defaults to
#                              vmbr0; skips creation if it already exists).
#
# Per-host LVM devices (the block devices basis wipes for its thin pool)
# go in host_vars/<host>.yml — see host_vars/node-2.yml for an example.
# Required on every agent; the playbook fails fast otherwise. Controllers
# don't need it.

[basis_controller]
10.0.0.10

[basis_agents]
10.0.0.11
10.0.0.12
10.0.0.21
10.0.0.22
10.0.0.23

[basis:children]
basis_controller
basis_agents

[basis:vars]
ansible_user=root
