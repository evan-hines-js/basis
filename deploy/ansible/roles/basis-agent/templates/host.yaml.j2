apiVersion: basis.dev/v1alpha1
kind: Host
metadata:
  name: {{ inventory_hostname }}
spec:
  controllerEndpoint: "https://{{ hostvars[groups['basis_controller'][0]].ansible_host }}:{{ basis_controller_port }}"
  dataDir: {{ basis_data_dir }}
  network:
    bridge: {{ basis_bridge }}
    physicalNic: {{ basis_physical_nic }}
  tls:
    cert: {{ basis_tls_dir }}/agent.crt
    key: {{ basis_tls_dir }}/agent.key
    ca: {{ basis_tls_dir }}/ca.crt
