{# `basis_controller` holds a single host; fall back to its inventory name
   (typically the raw IP) when `ansible_host` isn't set. #}
{% set controller = groups['basis_controller'][0] %}
{% set controller_addr = hostvars[controller].ansible_host | default(controller) %}
apiVersion: basis.dev/v1alpha1
kind: Host
metadata:
  name: "{{ inventory_hostname }}"
spec:
  controllerEndpoint: "https://{{ controller_addr }}:{{ basis_controller_port }}"
  dataDir: {{ basis_data_dir }}
  network:
    bridge: {{ basis_bridge }}
    physicalNic: {{ basis_physical_nic }}
  storage:
    rootfs:
      vg: {{ basis_lvm_vg }}
      thinPool: {{ basis_lvm_thinpool }}
    data:
      vg: {{ basis_lvm_data_vg }}
  tls:
    cert: {{ basis_tls_dir }}/agent.crt
    key: {{ basis_tls_dir }}/agent.key
    ca: {{ basis_tls_dir }}/ca.crt
{% if basis_agent_registries %}
  registries:
{% for r in basis_agent_registries %}
    - host: {{ r.host }}
      username: {{ r.username }}
      password: {{ r.password }}
{% endfor %}
{% endif %}
  rank: {{ basis_host_rank }}
{% if basis_host_labels %}
  labels:
{% for k, v in (basis_host_labels | dictsort) %}
    {{ k }}: {{ v }}
{% endfor %}
{% endif %}
