apiVersion: basis.dev/v1alpha1
kind: BasisController
metadata:
  name: "{{ inventory_hostname }}"
spec:
  listen: "0.0.0.0:{{ basis_controller_port }}"
  metricsListen: "0.0.0.0:{{ basis_controller_metrics_port }}"
  dataDir: {{ basis_data_dir }}
  tls:
    cert: {{ basis_tls_dir }}/controller.crt
    key: {{ basis_tls_dir }}/controller.key
    ca: {{ basis_tls_dir }}/ca.crt
  ipPools:
    - name: {{ basis_ip_pool.name }}
      cidr: {{ basis_ip_pool.cidr }}
      gateway: {{ basis_ip_pool.gateway }}
      vmRange:
        start: {{ basis_ip_pool.vm_range_start }}
        end: {{ basis_ip_pool.vm_range_end }}
      vipRange:
        start: {{ basis_ip_pool.vip_range_start }}
        end: {{ basis_ip_pool.vip_range_end }}
{% if basis_dns_servers is defined %}
  dnsServers:
{% for dns in basis_dns_servers %}
    - {{ dns }}
{% endfor %}
{% endif %}
  cpuOvercommitRatio: {{ basis_cpu_overcommit_ratio }}
